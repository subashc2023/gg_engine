Scene: Audio Test
Entities:
# ── Camera ────────────────────────────────────────────────────
- Entity: 100
  TagComponent:
    Tag: Camera
  TransformComponent:
    Translation:
    - 0.0
    - 0.0
    - 0.0
    Rotation:
    - 0.0
    - 0.0
    - 0.0
    Scale:
    - 1.0
    - 1.0
    - 1.0
  CameraComponent:
    Camera:
      ProjectionType: 1
      PerspectiveFOV: 0.7853982
      PerspectiveNear: 0.01
      PerspectiveFar: 1000.0
      OrthographicSize: 10.0
      OrthographicNear: -1.0
      OrthographicFar: 1.0
    Primary: true
    FixedAspectRatio: false

# ── Audio Entity (manual play via Lua) ────────────────────────
# Uses test_tone.wav (handle 1001). Script controls playback.
- Entity: 200
  TagComponent:
    Tag: Audio Player
  TransformComponent:
    Translation:
    - 0.0
    - 0.0
    - 0.0
    Rotation:
    - 0.0
    - 0.0
    - 0.0
    Scale:
    - 1.0
    - 1.0
    - 1.0
  SpriteRendererComponent:
    Color:
    - 0.2
    - 0.6
    - 0.9
    - 1.0
    TilingFactor: 1.0
  AudioSourceComponent:
    AudioHandle: 1001
    Volume: 1.0
    Pitch: 1.0
    Looping: true
    PlayOnStart: false
  LuaScriptComponent:
    ScriptPath: assets/scripts/audio_test.lua

# ── Auto-Play Audio Entity ────────────────────────────────────
# Plays automatically on runtime start (PlayOnStart: true).
- Entity: 300
  TagComponent:
    Tag: Auto Player
  TransformComponent:
    Translation:
    - 3.0
    - 0.0
    - 0.0
    Rotation:
    - 0.0
    - 0.0
    - 0.0
    Scale:
    - 0.5
    - 0.5
    - 1.0
  SpriteRendererComponent:
    Color:
    - 0.9
    - 0.4
    - 0.2
    - 1.0
    TilingFactor: 1.0
  AudioSourceComponent:
    AudioHandle: 1001
    Volume: 0.3
    Pitch: 1.5
    Looping: false
    PlayOnStart: true

