Version: 2
Scene: HRTF Audio Test
Entities:
# ── Camera / Listener ─────────────────────────────────────────
# First-person camera at eye height. WASD + mouse look.
- Entity: 100
  TagComponent:
    Tag: Camera
  TransformComponent:
    Translation:
    - 0.0
    - 1.5
    - 0.0
    Rotation:
    - 0.0
    - 0.0
    - 0.0
    - 1.0
    Scale:
    - 1.0
    - 1.0
    - 1.0
