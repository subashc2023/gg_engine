      ProjectionType: 0
      PerspectiveFOV: 0.7853982
      PerspectiveNear: 0.1
      PerspectiveFar: 200.0
      OrthographicSize: 10.0
      OrthographicNear: -1.0
      OrthographicFar: 1.0
    Primary: true
    FixedAspectRatio: false
  AudioListenerComponent:
    Active: true

# ── Controller (Lua script) ──────────────────────────────────
- Entity: 150
