    - 0.0
    - 0.0
    Rotation:
    - 0.0
    - 0.0
    - 0.0
    Scale:
    - 1.0
    - 1.0
    - 1.0
  SpriteRendererComponent:
    Color:
    - 0.4
    - 0.9
    - 0.2
    - 1.0
    TilingFactor: 1.0
  ParticleEmitterComponent:
    EmitRate: 8
    MaxParticles: 100000
    Playing: true
    Velocity:
    - 0.0
    - 0.5
    VelocityVariation:
    - 4.0
    - 4.0
    ColorBegin:
    - 0.5
    - 1.0
    - 0.2
    - 1.0
    ColorEnd:
    - 1.0
    - 0.9
    - 0.1
    - 0.0
    SizeBegin: 0.12
    SizeEnd: 0.0
    SizeVariation: 0.08
