{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug GGEditor",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/gg_editor.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cargo build (gg_editor)",
            "externalConsole": true,
            "stopAtEntry": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set disassembly flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
