{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo build",
            "type": "shell",
            "command": "cargo",
            "args": ["build"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "cargo build (gg_editor)",
            "type": "shell",
            "command": "cargo",
            "args": ["build", "-p", "gg_editor"],
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "cargo build (gg_sandbox)",
            "type": "shell",
            "command": "cargo",
            "args": ["build", "-p", "gg_sandbox"],
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "cargo build release (gg_editor)",
            "type": "shell",
            "command": "cargo",
            "args": ["build", "--release", "-p", "gg_editor"],
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "cargo build release (gg_sandbox)",
            "type": "shell",
            "command": "cargo",
            "args": ["build", "--release", "-p", "gg_sandbox"],
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "cargo test",
            "type": "shell",
            "command": "cargo",
            "args": ["test"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": ["$rustc"]
        }
    ]
}
